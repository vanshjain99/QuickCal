---
// src/pages/contact.astro
// Contact Us MPA Route for QuickCal
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us | QuickCal - Support & Inquiries"
  description="Have questions or feedback about QuickCal? Reach out to our support team for help with importing your class schedules and timetables."
>
  <section class="relative overflow-hidden min-h-[calc(100dvh-64px+20px)] w-full bg-canvas flex flex-col items-center pt-12 pb-20 md:pt-16 md:pb-28 border-b border-hairline animate-fade-in">
    <!-- Atmospheric Background -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-35 blur-[130px] flex items-center justify-center">
      <div class="w-[350px] h-[350px] rounded-full bg-gradient-to-r from-gradient-develop-start to-gradient-develop-end transform -translate-x-1/4"></div>
      <div class="w-[300px] h-[300px] rounded-full bg-gradient-to-r from-gradient-preview-start to-gradient-preview-end transform translate-x-1/4"></div>
    </div>

    <div class="relative z-10 w-full max-w-lg mx-auto px-4 text-left flex flex-col gap-8">
      <!-- Heading Section -->
      <div class="text-center flex flex-col gap-3">
        <span class="font-mono text-[11px] text-mute uppercase tracking-widest font-bold font-semibold">Get in Touch</span>
        <h1 class="font-sans font-extrabold text-3xl sm:text-4xl md:text-5xl leading-tight tracking-[-1.6px] text-ink">
          Contact Us
        </h1>
        <p class="font-sans text-body text-sm leading-relaxed text-balance max-w-sm mx-auto opacity-95">
          Have feedback, a feature request, or encountered a problem? Shoot us a message below and we will get back to you shortly.
        </p>
      </div>

      <!-- Contact Form Card -->
      <div class="bg-canvas border border-hairline rounded-md shadow-level-3 p-6 sm:p-8 flex flex-col gap-5 w-full">
        <!-- Form Feedback Banner (Success State) -->
        <div 
          id="contact-success-banner" 
          class="hidden p-3 bg-link-bg-soft border border-link/20 rounded-sm flex items-start gap-2 text-link-deep transition-all duration-300"
          role="alert"
        >
          <svg class="w-5 h-5 shrink-0 mt-[2px] text-link" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h4 class="font-sans font-semibold text-xs sm:text-sm tracking-[-0.28px]">Message Sent!</h4>
            <p class="text-[11px] sm:text-xs mt-[2px] opacity-90">Thank you for reaching out. We have received your inquiry and will respond soon.</p>
          </div>
        </div>

        <!-- Interactive Form -->
        <form id="contact-form" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label for="contact-name" class="font-mono text-[11px] text-mute uppercase tracking-wider font-semibold">
              Full Name
            </label>
            <input 
              type="text" 
              id="contact-name" 
              name="name" 
              required 
              placeholder="Jane Doe"
              class="w-full bg-canvas border border-hairline rounded-xs px-3 py-2 text-[13px] font-medium text-ink focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contact-email" class="font-mono text-[11px] text-mute uppercase tracking-wider font-semibold">
              Email Address
            </label>
            <input 
              type="email" 
              id="contact-email" 
              name="email" 
              required 
              placeholder="jane@example.com"
              class="w-full bg-canvas border border-hairline rounded-xs px-3 py-2 text-[13px] font-medium text-ink focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="contact-message" class="font-mono text-[11px] text-mute uppercase tracking-wider font-semibold">
              Message
            </label>
            <textarea 
              id="contact-message" 
              name="message" 
              required 
              rows="5"
              placeholder="Hi support, I tried to upload my PDF timetable but..."
              class="w-full bg-canvas border border-hairline rounded-xs px-3 py-2 text-[13px] font-medium text-ink focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20 resize-y min-h-[100px]"
            ></textarea>
          </div>

          <button 
            type="submit" 
            id="btn-send-message"
            class="w-full h-10 text-xs font-semibold rounded-sm bg-primary text-on-primary hover:bg-primary/95 transition-all duration-200 flex items-center justify-center gap-1.5 shadow-level-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successBanner = document.getElementById('contact-success-banner');
  const submitBtn = document.getElementById('btn-send-message');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const email = formData.get('email') as string;
      const message = formData.get('message') as string;

      // Visual Feedback flow
      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = true;
        submitBtn.textContent = 'Sending Message...';
      }

      try {
        const response = await fetch('http://127.0.0.1:8000/api/v1/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ name, email, message }),
        });

        if (!response.ok) {
          throw new Error('Failed to submit message to the server.');
        }

        // Reset form inputs
        form.reset();
        
        // Show banner
        if (successBanner) {
          successBanner.classList.remove('hidden');
          successBanner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      } catch (err) {
        console.error(err);
        alert('Could not send message. Please try again later.');
      } finally {
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = false;
          submitBtn.textContent = 'Send Message';
        }
      }
    });
  }
</script>
