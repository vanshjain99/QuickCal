---
// index.astro
// Core landing page for Schedule to Calendar
import Layout from '../layouts/Layout.astro';
import UploadZone from '../components/UploadZone.astro';
---
<Layout>
  <section id="uploader" class="relative overflow-hidden min-h-[calc(100dvh-64px+20px)] w-full bg-canvas flex flex-col items-center justify-center pt-6 pb-20 md:pt-8 md:pb-28 border-b border-hairline">
    <!-- Atmospheric Ambient Mesh Gradient Background (Vercel Style) -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-40 blur-[130px] flex items-center justify-center">
      <div class="w-[300px] h-[300px] rounded-full bg-gradient-to-r from-gradient-develop-start to-gradient-develop-end transform translate-x-[-100px] translate-y-[-50px]"></div>
      <div class="w-[320px] h-[320px] rounded-full bg-gradient-to-r from-gradient-preview-start to-gradient-preview-end transform translate-x-[120px] translate-y-[20px]"></div>
      <div class="w-[280px] h-[280px] rounded-full bg-gradient-to-r from-gradient-ship-start to-gradient-ship-end transform translate-y-[-120px]"></div>
    </div>

    <!-- Content Container -->
    <div class="relative z-10 w-full max-w-[1400px] mx-auto px-4 md:px-6 text-center flex flex-col items-center gap-4">
      <!-- Announcement Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-[6px] bg-canvas-soft-2 border border-hairline rounded-full shadow-level-1 transition-all duration-300 hover:border-hairline-strong select-none">
        <span class="inline-block px-1 py-[2px] bg-primary text-on-primary text-[9px] font-bold uppercase rounded-xs tracking-wider">New</span>
        <span class="font-sans text-[12px] font-medium text-body">Instant Timetable to Google Calendar sync</span>
      </div>

      <!-- Main Landing Title -->
      <h1 class="max-w-3xl font-sans font-extrabold text-[36px] sm:text-[44px] md:text-[56px] leading-[1.05] tracking-[-2.4px] text-ink text-balance">
        Sync your timetable in seconds.
      </h1>

      <!-- Supporting Body -->
      <p class="max-w-2xl font-sans text-body text-sm sm:text-base leading-relaxed text-balance opacity-90">
        Drop a screenshot of your schedule (work, class, or gym). Our privacy-first vision model instantly extracts your classes so you can import them to your google calendar with just a click.
      </p>

      <!-- Drag-and-Drop Zone Component -->
      <div id="upload-zone-wrapper" class="w-full max-w-2xl mt-4">
        <UploadZone />
      </div>

      <!-- Parsed Events Preview Drawer (Hidden by default, triggered on custom timetableParsed event) -->
      <div id="parsed-results-wrapper" class="hidden w-full max-w-2xl mt-6 flex flex-col gap-4 text-left transition-all duration-300">
        <div class="w-full text-center mb-2">
          <span class="font-mono text-[11px] text-mute uppercase tracking-widest font-bold">Step 2</span>
          <h2 class="font-sans font-semibold text-lg md:text-xl text-ink tracking-[-0.6px] mt-1">
            Review schedule
          </h2>
        </div>

        <!-- Vercel-like Preview Card -->
        <div class="bg-canvas border border-hairline rounded-md shadow-level-3 p-4 flex flex-col gap-3 overflow-hidden">
          <div class="flex items-center justify-between border-b border-hairline pb-3">
            <h3 class="font-sans font-semibold text-sm tracking-[-0.28px] text-ink">
              Extracted Calendar Items
            </h3>
            <span class="font-mono text-[11px] text-success bg-link-bg-soft px-2 py-1 rounded-pill font-medium">
              3 events parsed
            </span>
          </div>

          <!-- Top Action Buttons (Duplicated) -->
          <div class="flex items-center justify-between pb-3 border-b border-hairline mb-2">
            <button 
              type="button"
              class="btn-add-row h-9 px-3 text-xs font-medium border border-hairline hover:border-hairline-strong rounded-sm bg-canvas text-body hover:text-ink transition-all duration-200 flex items-center gap-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Add New Row
            </button>
            <div class="flex items-center gap-3">
              <button 
                type="button"
                class="btn-discard h-9 px-3 text-xs font-medium border border-hairline hover:border-hairline-strong rounded-sm bg-canvas text-body hover:text-ink transition-all duration-200 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
              >
                Clear & Reupload
              </button>
              <button 
                type="button"
                class="btn-sync h-9 px-3 text-xs font-medium rounded-sm bg-primary text-on-primary hover:bg-primary/95 transition-all duration-200 flex items-center gap-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 512 512" aria-hidden="true">
                  <path d="M256,48C141.31,48,48,141.31,48,256S141.31,464,256,464,464,370.69,464,256,370.69,48,256,48Zm96.25,222.51l-128,80A15.86,15.86,0,0,1,216,352a16,16,0,0,1-16-16V176a16,16,0,0,1,24.25-13.49l128,80a16,16,0,0,1,0,27Z" />
                </svg>
                Confirm & Sync with Google Calendar
              </button>
            </div>
          </div>

          <!-- Event Data Table -->
          <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left">
              <thead>
                <tr class="border-b border-hairline text-mute">
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold w-1/4">Class / Event</th>
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold w-[120px]">Day</th>
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold w-[150px]">Time</th>
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold w-1/5">Location</th>
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold">Weekly Repeat</th>
                  <th class="font-mono text-[11px] uppercase tracking-wider py-3 px-2 font-semibold w-[60px] text-center">Delete</th>
                </tr>
              </thead>
              <tbody id="parsed-events-tbody" class="divide-y divide-hairline">
                <!-- Dynamically populated rows -->
              </tbody>
            </table>
          </div>

          <!-- Bottom Action Buttons -->
          <div class="flex items-center justify-between pt-3 border-t border-hairline mt-2">
            <button 
              id="btn-add-row" 
              class="btn-add-row h-9 px-3 text-xs font-medium border border-hairline hover:border-hairline-strong rounded-sm bg-canvas text-body hover:text-ink transition-all duration-200 flex items-center gap-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
              Add New Row
            </button>
            <div class="flex items-center gap-3">
              <button 
                id="btn-discard" 
                class="btn-discard h-9 px-3 text-xs font-medium border border-hairline hover:border-hairline-strong rounded-sm bg-canvas text-body hover:text-ink transition-all duration-200 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
              >
                Clear & Reupload
              </button>
              <button 
                id="btn-sync" 
                class="btn-sync h-9 px-3 text-xs font-medium rounded-sm bg-primary text-on-primary hover:bg-primary/95 transition-all duration-200 flex items-center gap-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 512 512" aria-hidden="true">
                  <path d="M256,48C141.31,48,48,141.31,48,256S141.31,464,256,464,464,370.69,464,256,370.69,48,256,48Zm96.25,222.51l-128,80A15.86,15.86,0,0,1,216,352a16,16,0,0,1-16-16V176a16,16,0,0,1,24.25-13.49l128,80a16,16,0,0,1,0,27Z" />
                </svg>
                Confirm & Sync with Google Calendar
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Success Confirmation Card (Hidden by default) -->
      <div id="sync-success-wrapper" class="hidden w-full max-w-md mt-6 flex flex-col gap-4 text-center items-center transition-all duration-500 transform translate-y-4 opacity-0">
        <div class="bg-canvas border border-hairline rounded-md shadow-level-4 p-8 flex flex-col items-center gap-5 w-full">
          <!-- Animated Check Circle (Premium UI SVG) -->
          <div class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center text-success animate-bounce-subtle">
            <svg class="w-8 h-8 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path class="draw-path" d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline class="draw-checkmark" points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          
          <div class="flex flex-col gap-2">
            <h3 class="font-sans font-extrabold text-xl text-ink tracking-[-0.6px]">
              Sync Completed!
            </h3>
            <p id="success-description" class="font-sans text-xs text-body leading-relaxed max-w-sm">
              Successfully synced all your classes to your Google Calendar.
            </p>
          </div>

          <!-- Action buttons for success -->
          <div class="flex flex-col sm:flex-row gap-3 w-full mt-2">
            <a 
              href="https://calendar.google.com" 
              target="_blank" 
              rel="noopener noreferrer"
              class="flex-1 h-10 text-xs font-semibold rounded-sm bg-primary text-on-primary hover:bg-primary/95 flex items-center justify-center gap-1.5 transition-all duration-200 shadow-level-1 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2"
            >
              Open Google Calendar
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <button 
              id="btn-sync-another"
              class="flex-1 h-10 text-xs font-semibold rounded-sm border border-hairline hover:border-hairline-strong bg-canvas text-body hover:text-ink transition-all duration-200 focus-visible:outline-2 focus-visible:outline-primary focus-visible:outline-offset-2 cursor-pointer"
            >
              Sync Another Schedule
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mock Toast Alert -->
  <div 
    id="toast-notification" 
    class="fixed bottom-6 right-6 z-[100] transform translate-y-24 opacity-0 transition-all duration-300 p-3 bg-primary text-on-primary rounded-sm shadow-level-4 flex items-center gap-2 max-w-sm pointer-events-none"
    role="alert"
  >
    <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span id="toast-message" class="text-xs font-sans font-medium">Calendar sync completed successfully!</span>
  </div>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';
  const resultsWrapper = document.getElementById('parsed-results-wrapper');
  const uploadWrapper = document.getElementById('upload-zone-wrapper');
  const tbody = document.getElementById('parsed-events-tbody');
  const discardBtns = document.querySelectorAll('.btn-discard');
  const addRowBtns = document.querySelectorAll('.btn-add-row');
  const syncBtns = document.querySelectorAll('.btn-sync');
  const toast = document.getElementById('toast-notification');
  const toastMessage = document.getElementById('toast-message');

  let currentEvents: any[] = [];

  // Re-usable table row renderer
  function renderTable() {
    if (!tbody) return;
    tbody.innerHTML = '';

    currentEvents.forEach((evt: any, index: number) => {
      const row = document.createElement('tr');
      row.className = 'group hover:bg-canvas-soft-2 transition-colors duration-150';
      row.setAttribute('data-index', index.toString());

      // Ensure weekly_days contains at least the day_of_week if not already there
      if (!evt.weekly_days) {
        evt.weekly_days = [evt.day_of_week];
      }

      // Days of the week for recurrence selection
      const days = [
        { key: 'MONDAY', label: 'M' },
        { key: 'TUESDAY', label: 'T' },
        { key: 'WEDNESDAY', label: 'W' },
        { key: 'THURSDAY', label: 'T' },
        { key: 'FRIDAY', label: 'F' },
        { key: 'SATURDAY', label: 'S' },
        { key: 'SUNDAY', label: 'S' }
      ];

      const daysHtml = days.map(d => {
        const isActive = evt.weekly_days.includes(d.key);
        const activeClasses = 'bg-primary text-on-primary font-semibold';
        const inactiveClasses = 'bg-canvas border border-hairline text-mute hover:text-body hover:border-hairline-strong';
        return `
          <button 
            type="button"
            data-day="${d.key}"
            data-index="${index}"
            class="w-6 h-6 text-[10px] rounded-full flex items-center justify-center transition-all duration-150 select-none cursor-pointer ${isActive ? activeClasses : inactiveClasses}"
            title="Repeat on ${formatDay(d.key)}"
          >
            ${d.label}
          </button>
        `;
      }).join('');

      row.innerHTML = `
        <td class="py-3 px-2">
          <input 
            type="text" 
            value="${evt.title || ''}" 
            class="w-full bg-canvas border border-hairline rounded-xs px-2 py-1 text-[13px] font-semibold text-ink focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
            data-field="title"
            data-index="${index}"
          />
        </td>
        <td class="py-3 px-2">
          <select 
            class="w-full bg-canvas border border-hairline rounded-xs px-2 py-1 text-[13px] text-body focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
            data-field="day_of_week"
            data-index="${index}"
          >
            ${['MONDAY', 'TUESDAY', 'WEDNESDAY', 'THURSDAY', 'FRIDAY', 'SATURDAY', 'SUNDAY'].map(day => `
              <option value="${day}" ${evt.day_of_week === day ? 'selected' : ''}>
                ${formatDay(day)}
              </option>
            `).join('')}
          </select>
        </td>
        <td class="py-3 px-2">
          <div class="flex items-center gap-1">
            <input 
              type="text" 
              placeholder="09:00"
              value="${evt.start_time || ''}" 
              class="w-[58px] bg-canvas border border-hairline rounded-xs px-1.5 py-1 text-[12px] text-mono text-center focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
              data-field="start_time"
              data-index="${index}"
            />
            <span class="text-mute text-xs">-</span>
            <input 
              type="text" 
              placeholder="10:00"
              value="${evt.end_time || ''}" 
              class="w-[58px] bg-canvas border border-hairline rounded-xs px-1.5 py-1 text-[12px] text-mono text-center focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
              data-field="end_time"
              data-index="${index}"
            />
          </div>
        </td>
        <td class="py-3 px-2">
          <input 
            type="text" 
            value="${evt.location || ''}" 
            placeholder="Room/Building"
            class="w-full bg-canvas border border-hairline rounded-xs px-2 py-1 text-[13px] text-mute focus:border-hairline-strong focus:outline-none focus:ring-1 focus:ring-primary/20"
            data-field="location"
            data-index="${index}"
          />
        </td>
        <td class="py-3 px-2">
          <div class="flex items-center gap-1">
            ${daysHtml}
          </div>
        </td>
        <td class="py-3 px-2 text-center">
          <button 
            type="button"
            data-action="delete"
            data-index="${index}"
            class="p-1.5 text-error-deep hover:bg-error-soft/30 rounded-xs transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-error cursor-pointer"
            title="Delete event"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </td>
      `;
      tbody.appendChild(row);
    });

    // Update count badge
    const badge = document.querySelector('.text-success.bg-link-bg-soft');
    if (badge) {
      badge.textContent = `${currentEvents.length} event${currentEvents.length === 1 ? '' : 's'} parsed`;
    }
  }

  // Listen to the custom event bubbled up from UploadZone
  document.addEventListener('timetableParsed', (event: Event) => {
    const customEvent = event as CustomEvent;
    const data = customEvent.detail;
    
    if (data?.events) {
      // 1. Copy parsed events into local state
      currentEvents = JSON.parse(JSON.stringify(data.events));

      // 2. Render table
      renderTable();

      // 3. Hide UploadZone, Show Results
      if (uploadWrapper) {
        uploadWrapper.classList.add('hidden');
      }
      if (resultsWrapper) {
        resultsWrapper.classList.remove('hidden');
        resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  });

  // Listen for edits in input and select elements
  if (tbody) {
    tbody.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement;
      const field = target.getAttribute('data-field');
      const indexAttr = target.getAttribute('data-index');
      
      if (field && indexAttr) {
        const index = parseInt(indexAttr, 10);
        const eventObj = currentEvents[index];
        if (eventObj) {
          eventObj[field] = target.value;
          console.log(`Updated state index ${index} [${field}]:`, target.value);
        }
      }
    });

    tbody.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement | HTMLSelectElement;
      const field = target.getAttribute('data-field');
      const indexAttr = target.getAttribute('data-index');
      
      if (field && indexAttr) {
        const index = parseInt(indexAttr, 10);
        const eventObj = currentEvents[index];
        if (eventObj) {
          eventObj[field] = target.value;
          console.log(`Committed state index ${index} [${field}]:`, target.value);
          // Auto-align weekly_days if it was only matching the day_of_week
          if (field === 'day_of_week') {
            const oldDays = eventObj.weekly_days || [];
            if (oldDays.length <= 1) {
              eventObj.weekly_days = [target.value];
              renderTable();
            }
          }
        }
      }
    });

    tbody.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // Delete Row
      const deleteButton = target.closest('button[data-action="delete"]');
      if (deleteButton) {
        e.preventDefault();
        e.stopPropagation();
        const indexAttr = deleteButton.getAttribute('data-index');
        if (indexAttr) {
          const index = parseInt(indexAttr, 10);
          currentEvents.splice(index, 1);
          renderTable();
          console.log(`Deleted event at index ${index}. Remaining:`, currentEvents);
        }
        return;
      }

      // Toggle Recurrence Day
      const dayButton = target.closest('button[data-day]');
      if (dayButton) {
        e.preventDefault();
        e.stopPropagation();
        const day = dayButton.getAttribute('data-day');
        const indexAttr = dayButton.getAttribute('data-index');
        if (day && indexAttr) {
          const index = parseInt(indexAttr, 10);
          const eventObj = currentEvents[index];
          if (eventObj) {
            if (!eventObj.weekly_days) {
              eventObj.weekly_days = [];
            }
            
            const dayIdx = eventObj.weekly_days.indexOf(day);
            if (dayIdx > -1) {
              eventObj.weekly_days.splice(dayIdx, 1);
            } else {
              eventObj.weekly_days.push(day);
            }
            renderTable();
            console.log(`Toggled weekly day repeat for index ${index}:`, eventObj.weekly_days);
          }
        }
      }
    });
  }

  // Add New Row handler
  addRowBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const newEvent = {
        title: "New Class",
        day_of_week: "MONDAY",
        start_time: "09:00",
        end_time: "10:00",
        location: "",
        weekly_days: ["MONDAY"]
      };
      currentEvents.push(newEvent);
      renderTable();
      console.log('Added new event row:', newEvent);
      
      if (tbody && tbody.lastElementChild) {
        tbody.lastElementChild.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });

  // Discard / Reupload handler
  discardBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      currentEvents = [];
      if (resultsWrapper) {
        resultsWrapper.classList.add('hidden');
      }
      if (uploadWrapper) {
        uploadWrapper.classList.remove('hidden');
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Google Identity Services (GIS) Token Client State
  let tokenClient: any = null;

  function initTokenClient() {
    if (tokenClient) return tokenClient;

    if (typeof window !== 'undefined' && (window as any).google?.accounts?.oauth2) {
      const clientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
      if (!clientId) {
        console.error('PUBLIC_GOOGLE_CLIENT_ID environment variable is missing.');
        showToast('Configuration error: Google Client ID is not set.', false);
        return null;
      }

      tokenClient = (window as any).google.accounts.oauth2.initTokenClient({
        client_id: clientId,
        scope: 'https://www.googleapis.com/auth/calendar.events',
        callback: async (tokenResponse: any) => {
          if (tokenResponse && tokenResponse.access_token) {
            await executeSync(tokenResponse.access_token);
          } else {
            showToast('OAuth authentication failed: No access token returned.', false);
            resetSyncButton();
          }
        },
        error_callback: (err: any) => {
          console.error('Google OAuth error:', err);
          showToast(`Authentication error: ${err.message || 'Check browser console.'}`, false);
          resetSyncButton();
        }
      });
      return tokenClient;
    }
    return null;
  }

  function resetSyncButton() {
    syncBtns.forEach(btn => {
      (btn as HTMLButtonElement).disabled = false;
      btn.innerHTML = `
        <svg class="w-4 h-4 fill-current" viewBox="0 0 512 512" aria-hidden="true">
          <path d="M256,48C141.31,48,48,141.31,48,256S141.31,464,256,464,464,370.69,464,256,370.69,48,256,48Zm96.25,222.51l-128,80A15.86,15.86,0,0,1,216,352a16,16,0,0,1-16-16V176a16,16,0,0,1,24.25-13.49l128,80a16,16,0,0,1,0,27Z" />
        </svg>
        Confirm & Sync with Google Calendar
      `;
    });
  }

  async function executeSync(accessToken: string) {
    syncBtns.forEach(btn => {
      (btn as HTMLButtonElement).disabled = true;
      btn.textContent = 'Syncing schedule...';
    });

    try {
      // Clean and sanitize the event payload to strictly match Pydantic schema
      const sanitizedEvents = currentEvents.map(evt => ({
        title: evt.title || 'Untitled Class',
        day_of_week: evt.day_of_week || 'MONDAY',
        start_time: evt.start_time || '09:00',
        end_time: evt.end_time || '10:00',
        location: evt.location ? evt.location.trim() : null,
        weekly_days: Array.isArray(evt.weekly_days) && evt.weekly_days.length > 0 
          ? evt.weekly_days 
          : [evt.day_of_week || 'MONDAY']
      }));

      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'Asia/Kolkata';

      const payload = {
        access_token: accessToken,
        events: sanitizedEvents,
        timezone: tz
      };

      console.log('Sending sync payload to backend:', payload);

      const response = await fetch(`${API_URL}/api/v1/sync`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      if (!response.ok) {
        let errText = 'Server error occurred during synchronization.';
        try {
          const errData = await response.json();
          if (errData && errData.detail) {
            errText = typeof errData.detail === 'string' ? errData.detail : JSON.stringify(errData.detail);
          }
        } catch (_) {
          errText = response.statusText || errText;
        }
        throw new Error(errText);
      }

      const resData = await response.json();
      console.log('Sync response:', resData);

      // Show success screen
      showSuccessScreen(resData.synced_count || sanitizedEvents.length);

    } catch (err: any) {
      console.error('Sync failure:', err);
      showToast(err.message || 'Sync failed due to a network error.', false);
      resetSyncButton();
    }
  }

  function showSuccessScreen(count: number) {
    if (resultsWrapper) {
      resultsWrapper.classList.add('hidden');
    }

    const successWrapper = document.getElementById('sync-success-wrapper');
    const successDescription = document.getElementById('success-description');

    if (successWrapper) {
      if (successDescription) {
        successDescription.textContent = `Successfully synchronized ${count} event${count === 1 ? '' : 's'} directly to your Google Calendar.`;
      }
      
      successWrapper.classList.remove('hidden');
      // Trigger CSS transition
      setTimeout(() => {
        successWrapper.classList.remove('translate-y-4', 'opacity-0');
        successWrapper.classList.add('translate-y-0', 'opacity-100');
      }, 50);

      successWrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  // Sync Button Handlers
  syncBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Disable and show status on all sync buttons
      syncBtns.forEach(b => {
        (b as HTMLButtonElement).disabled = true;
        b.textContent = 'Authenticating...';
      });

      const client = initTokenClient();
      if (client) {
        client.requestAccessToken();
      } else {
        if (!(window as any).google?.accounts?.oauth2) {
          showToast('Google identity library is still loading. Please try again in a moment.', false);
        } else {
          showToast('Failed to initialize Google OAuth library. Check configuration.', false);
        }
        resetSyncButton();
      }
    });
  });

  // Sync Another Button Handler
  const syncAnotherBtn = document.getElementById('btn-sync-another');
  if (syncAnotherBtn) {
    syncAnotherBtn.addEventListener('click', () => {
      // Clear state
      currentEvents = [];
      
      // Hide success screen
      const successWrapper = document.getElementById('sync-success-wrapper');
      if (successWrapper) {
        successWrapper.classList.add('hidden', 'translate-y-4', 'opacity-0');
        successWrapper.classList.remove('translate-y-0', 'opacity-100');
      }

      // Show upload zone
      if (uploadWrapper) {
        uploadWrapper.classList.remove('hidden');
      }

      // Reset sync button text/disabled
      resetSyncButton();

      // Scroll to top
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  function formatDay(day: string) {
    if (!day) return '';
    return day.charAt(0).toUpperCase() + day.slice(1).toLowerCase();
  }

  function showToast(message: string, isSuccess: boolean) {
    if (toast && toastMessage) {
      toastMessage.textContent = message;
      
      const svgIcon = toast.querySelector('svg');
      
      if (isSuccess) {
        toast.classList.remove('bg-error-deep');
        toast.classList.add('bg-primary');
        if (svgIcon) {
          svgIcon.className.baseVal = "w-4 h-4 text-green-400 shrink-0";
          svgIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />';
        }
      } else {
        toast.classList.remove('bg-primary');
        toast.classList.add('bg-error-deep');
        if (svgIcon) {
          svgIcon.className.baseVal = "w-4 h-4 text-white shrink-0";
          svgIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />';
        }
      }

      toast.classList.remove('translate-y-24', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');

      if ((window as any).toastTimeout) {
        clearTimeout((window as any).toastTimeout);
      }
      
      (window as any).toastTimeout = setTimeout(() => {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('translate-y-24', 'opacity-0');
      }, 4000);
    }
  }
</script>

