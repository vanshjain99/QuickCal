---
// UploadZone.astro
// Core landing page component for uploading timetable screenshots
---

<div class="w-full max-w-2xl mx-auto px-4">
  <!-- Error Display Area -->
  <div 
    id="error-banner" 
    class="hidden mb-4 p-3 bg-error-soft border border-error/20 rounded-sm flex items-start gap-2 text-error-deep transition-all duration-200"
    role="alert"
  >
    <svg class="w-5 h-5 shrink-0 mt-[2px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <div class="flex-grow">
      <h4 class="font-sans font-semibold text-sm tracking-[-0.28px]">Upload Error</h4>
      <p id="error-message" class="text-xs mt-[2px] opacity-90"></p>
    </div>
    <button 
      id="close-error" 
      class="text-error-deep hover:bg-error-deep/10 rounded-xs p-1 transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-error"
      aria-label="Dismiss error"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Drag and Drop Zone -->
  <div
    id="dropzone-container"
    class="relative w-full h-[220px] md:h-[280px] bg-canvas border-2 border-dashed border-hairline rounded-md shadow-level-2 hover:shadow-level-3 hover:border-hairline-strong cursor-pointer flex flex-col items-center justify-center p-4 md:p-6 text-center select-none outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 transition-all duration-300"
    tabindex="0"
    role="button"
    aria-label="Upload timetable screenshot"
  >
    <input 
      type="file" 
      id="file-input" 
      accept="image/png, image/jpeg, image/jpg, application/pdf, application/vnd.ms-excel, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" 
      class="hidden" 
      tabindex="-1"
    />

    <!-- Idle State UI -->
    <div id="state-idle" class="flex flex-col items-center gap-2 transition-opacity duration-200">
      <div class="p-2 bg-canvas-soft-2 border border-hairline rounded-sm shadow-level-1 text-body">
        <svg class="w-6 h-6 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
        </svg>
      </div>
      <div class="flex flex-col gap-1 mt-1">
        <h3 class="font-sans font-semibold text-[16px] md:text-[18px] tracking-[-0.6px] text-ink leading-tight">
          <!-- Mobile instructions -->
          <span class="md:hidden">Tap to upload your timetable</span>
          <!-- Desktop instructions -->
          <span class="hidden md:inline">Drag & drop your timetable here, or <span class="text-link hover:underline">browse</span></span>
        </h3>
        <p class="font-mono text-[11px] text-mute uppercase tracking-wider">
          PNG, JPG, PDF, EXCEL &bull; Max 5MB
        </p>
      </div>
    </div>

    <!-- Loading State UI (Skeleton loader + text) -->
    <div id="state-loading" class="hidden w-full max-w-md flex flex-col items-center gap-4 transition-opacity duration-200">
      <!-- Minimalist Spinner -->
      <div class="relative w-8 h-8">
        <div class="w-full h-full rounded-full border-2 border-hairline"></div>
        <div class="absolute top-0 left-0 w-full h-full rounded-full border-2 border-primary border-t-transparent animate-spin"></div>
      </div>
      
      <div class="w-full flex flex-col gap-2 mt-1">
        <h3 class="font-sans font-semibold text-sm tracking-[-0.28px] text-ink animate-pulse">
          Extracting Schedule...
        </h3>
        
        <!-- Vercel-like Skeleton Grid Loader -->
        <div class="w-full bg-canvas-soft-2 border border-hairline rounded-sm p-3 flex flex-col gap-2 shadow-level-1">
          <div class="h-3 w-1/3 bg-hairline rounded-xs animate-pulse"></div>
          <div class="h-2 w-full bg-hairline/60 rounded-xs animate-pulse"></div>
          <div class="h-2 w-3/4 bg-hairline/60 rounded-xs animate-pulse"></div>
          <div class="flex gap-2 mt-1 justify-between">
            <div class="h-4 w-1/4 bg-hairline rounded-xs animate-pulse"></div>
            <div class="h-4 w-1/4 bg-hairline rounded-xs animate-pulse"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8000';
  // Active backend connection to /api/v1/extract
  const ALLOWED_MIME_TYPES = [
    'image/png', 
    'image/jpeg', 
    'image/jpg', 
    'application/pdf', 
    'application/vnd.ms-excel', 
    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
  ];
  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5MB

  const dropzone = document.getElementById('dropzone-container');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const errorBanner = document.getElementById('error-banner');
  const errorMessage = document.getElementById('error-message');
  const closeErrorBtn = document.getElementById('close-error');
  
  const stateIdle = document.getElementById('state-idle');
  const stateLoading = document.getElementById('state-loading');

  if (dropzone && fileInput) {
    // Click behavior (forwarding focus and click to file input)
    dropzone.addEventListener('click', () => {
      fileInput.click();
    });

    // Keyboard behavior (for accessibility)
    dropzone.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fileInput.click();
      }
    });

    // Drag-over styling states
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('bg-canvas-soft-2', 'border-primary');
    });

    dropzone.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dropzone.classList.add('bg-canvas-soft-2', 'border-primary');
    });

    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('bg-canvas-soft-2', 'border-primary');
    });

    dropzone.addEventListener('dragend', () => {
      dropzone.classList.remove('bg-canvas-soft-2', 'border-primary');
    });

    // Drop handler
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('bg-canvas-soft-2', 'border-primary');
      
      const files = e.dataTransfer?.files;
      if (files && files.length > 0) {
        validateAndProcessFile(files[0]);
      }
    });

    // Input file select handler
    fileInput.addEventListener('change', () => {
      const files = fileInput.files;
      if (files && files.length > 0) {
        validateAndProcessFile(files[0]);
      }
    });
  }

  // Error Banner Close Button
  if (closeErrorBtn && errorBanner) {
    closeErrorBtn.addEventListener('click', (e) => {
      e.stopPropagation(); // Avoid triggering dropzone click
      hideError();
    });
  }

  async function validateAndProcessFile(file: File) {
    hideError();

    const fileExtension = file.name.split('.').pop()?.toLowerCase();
    const allowedExtensions = ['png', 'jpg', 'jpeg', 'pdf', 'xls', 'xlsx'];
    const isAllowedExtension = fileExtension && allowedExtensions.includes(fileExtension);
    const isAllowedMime = ALLOWED_MIME_TYPES.includes(file.type);

    // 1. Validate File Type
    if (!isAllowedMime && !isAllowedExtension) {
      showError(`"${file.name}" has an invalid format. Please upload a PNG, JPG, PDF, or Excel file.`);
      return;
    }

    // 2. Validate File Size
    if (file.size > MAX_FILE_SIZE) {
      const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
      showError(`"${file.name}" is too large (${sizeInMB}MB). The maximum allowed file size is 5MB.`);
      return;
    }

    // 3. File is valid -> Transition to Loading State
    setLoadingState(true);
    if (dropzone) {
      dropzone.dispatchEvent(new CustomEvent('timetableParseStart', {
        bubbles: true,
        composed: true
      }));
    }

    // 4. Construct FormData and make Fetch API Call
    try {
      const formData = new FormData();
      formData.append('file', file);

      const response = await fetch(`${API_URL}/api/v1/extract`, {
        method: 'POST',
        body: formData,
      });

      if (!response.ok) {
        let errDetail = 'An error occurred while extracting the schedule.';
        try {
          const errData = await response.json();
          if (errData && errData.detail) {
            errDetail = typeof errData.detail === 'string' ? errData.detail : JSON.stringify(errData.detail);
          }
        } catch (_) {
          errDetail = response.statusText || errDetail;
        }
        throw new Error(errDetail);
      }

      const data = await response.json();
      console.log('Successfully received response from backend:', data);

      // Create and dispatch the custom DOM event with the parsed timetable JSON payload
      const customEvent = new CustomEvent('timetableParsed', {
        detail: data,
        bubbles: true,
        composed: true
      });
      
      if (dropzone) {
        dropzone.dispatchEvent(customEvent);
      }
    } catch (error: any) {
      console.error('Error during schedule extraction:', error);
      showError(error.message || 'Network error occurred. Please check if the backend is running.');
      
      // Dispatch failure end event
      if (dropzone) {
        dropzone.dispatchEvent(new CustomEvent('timetableParseEnd', {
          bubbles: true,
          composed: true
        }));
      }
    } finally {
      // Return state to idle (or let parent page redirect)
      setLoadingState(false);
      if (fileInput) {
        fileInput.value = ''; // Reset input so same file can be uploaded again
      }
    }
  }

  function showError(msg: string) {
    if (errorBanner && errorMessage) {
      errorMessage.textContent = msg;
      errorBanner.classList.remove('hidden');
    }
  }

  function hideError() {
    if (errorBanner) {
      errorBanner.classList.add('hidden');
    }
  }

  function setLoadingState(isLoading: boolean) {
    if (isLoading) {
      stateIdle?.classList.add('hidden');
      stateLoading?.classList.remove('hidden');
      if (dropzone) {
        dropzone.style.pointerEvents = 'none'; // Prevent double uploads
        dropzone.classList.add('shadow-inner');
      }
    } else {
      stateIdle?.classList.remove('hidden');
      stateLoading?.classList.add('hidden');
      if (dropzone) {
        dropzone.style.pointerEvents = 'auto';
        dropzone.classList.remove('shadow-inner');
      }
    }
  }
</script>
